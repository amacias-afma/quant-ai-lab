# ==========================================
# 5. THE ULTIMATE TEST: Out-of-Sample Evaluation
# ==========================================
print("\n--- Running Out-of-Sample (Validation) Evaluation ---")

# 1. Set the model to evaluation mode (turns off dropout)
trained_model.eval()

# 2. Isolate the exact validation data and dates
# (Using the same 20% split we used in training)
split_idx = int(len(X) * 0.8)
val_signatures = X[split_idx:]
val_targets = y[split_idx:]
val_dates = targets.index[:-1][split_idx:] 

# 3. Generate the Ensemble Predictions
# We pass the geometric signatures into the SDE to simulate the future
val_sig_tensor = torch.tensor(val_signatures, dtype=torch.float32)
predicted_ensembles_ai = trained_model.simulate_paths(val_sig_tensor, n_samples=2000)

# 4. Score the AI using our Universal Quant Engine
# We convert the targets back to a Pandas Series so the dates align in our plots
actual_returns_val = pd.Series(val_targets.flatten(), index=val_dates)

# THE MOMENT OF TRUTH: Pass it into the judge
df_eval_ai = evaluate_forecasts(actual_returns_val, predicted_ensembles_ai)

# ==========================================
# 6. PRINT RESULTS & COMPARE
# ==========================================
from src.evaluation.metrics import print_evaluation_summary, test_pit_uniformity, block_ks_test
from src.evaluation.plotting import plot_forecast_evaluation

print_evaluation_summary(df_eval_ai, ticker_name="Neural SDE (Out-of-Sample)")

# Global Test
print("\n--- GLOBAL K-S TEST ---")
test_pit_uniformity(df_eval_ai['PIT'])

# The Strict Independent Block Test
